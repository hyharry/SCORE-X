|| RuntimeControl		|| *(ss)		|| Parameter, Value
"XMAX"							"1.000"		// when does the integration scheme stop at the latest
"TIMEMAX"						"3600.0"	// simulated time upper bound
"NMAX"							"5000"		// generous step cap for a full small run
"PERCOLATIONANALYSIS"			"0"			// disabled
"MAXFILLPERSTEP"				"0.1"		// integrator stability
"RediscretizationSteps"			"500"		// lighter than the large examples, still useful kinetics output
"InitialCacheSizeRXCells"		"0.20"		// legacy-faithful cache guess
"ReCacheSizeRXCells"			"1.0"		// legacy-faithful recache factor
"OnTheFlyDefragmentation"		"1"			// keep runtime behavior realistic
"SolitaryUnitPostProcessing"	"1"			// produce rediscretized summary outputs
"ReadEBSDMapping"				"0"			// monocrystal JMAK-like case, no external EBSD input
"ReadEBSDStepsize"				"1.0E-06"	// ignored when EBSD off

|| SimulationOutput		|| *(ss)		|| Parameter, Value
