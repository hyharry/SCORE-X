"RenderingSectionYMIN"			"0.0"
"RenderingSectionZMIN"			"0.0"
"RenderingSectionXMAX"			"1.0"
"RenderingSectionYMAX"			"1.0"
"RenderingSectionZMAX"			"1.0"
"RenderingColorModel"			"1"			// legacy JMAK example used grain IDs
"RenderingFileFormat"			"1"
"RenderingBoundaries"			"0"
"OutputLogBoundaries"			"0"
"OutputRXFrontStats"			"0"
"OutputThreadProfiling"			"0"			// keep this light
"OutputSingleGrainStats"		"0"			// keep this light; kinetics/profiling still enough for regression
"OutputDAMASKGeometryFile"		"0"
"OutputArtificialSEMEBSD"		"0"

